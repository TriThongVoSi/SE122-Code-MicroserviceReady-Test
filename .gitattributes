# ==========================================================
# Cross-platform line ending normalization (Linux ↔ Windows)
# ==========================================================
# Git will normalize line endings to LF on commit, and
# check out with native line endings (LF on Linux, CRLF on Windows).

# Auto-detect text files and normalize line endings
* text=auto

# --- Source code (force LF) ---
*.java        text eol=lf
*.ts          text eol=lf
*.tsx         text eol=lf
*.js          text eol=lf
*.jsx         text eol=lf
*.css         text eol=lf
*.scss        text eol=lf
*.html        text eol=lf
*.json        text eol=lf
*.xml         text eol=lf
*.yml         text eol=lf
*.yaml        text eol=lf
*.md          text eol=lf
*.txt         text eol=lf
*.properties  text eol=lf
*.gradle      text eol=lf
*.sql         text eol=lf

# --- Config files (force LF) ---
*.env         text eol=lf
*.env.*       text eol=lf
.gitignore    text eol=lf
.gitattributes text eol=lf
.editorconfig text eol=lf
Dockerfile    text eol=lf
docker-compose* text eol=lf
Makefile      text eol=lf

# --- Shell scripts (must be LF) ---
*.sh          text eol=lf
*.bash        text eol=lf
mvnw          text eol=lf
gradlew       text eol=lf

# --- Windows-specific scripts (force CRLF) ---
*.bat         text eol=crlf
*.cmd         text eol=crlf
gradlew.bat   text eol=crlf
mvnw.cmd      text eol=crlf

# --- Binary files (no normalization) ---
*.png         binary
*.jpg         binary
*.jpeg        binary
*.gif         binary
*.ico         binary
*.svg         binary
*.webp        binary
*.woff        binary
*.woff2       binary
*.ttf         binary
*.eot         binary
*.otf         binary
*.pdf         binary
*.zip         binary
*.tar.gz      binary
*.jar         binary
*.war         binary
*.class       binary
*.lock        binary
