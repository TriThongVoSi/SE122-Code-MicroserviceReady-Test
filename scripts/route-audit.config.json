{
  "ignoreRules": [
    {
      "method": "*",
      "pathRegex": "^/api/v1/admin/users/farmers(?:/.*)?$",
      "reason": "legacy-admin-farmer-management-api-not-exposed"
    },
    {
      "method": "*",
      "pathRegex": "^/api/v1/admin/suppliers(?:/.*)?$",
      "reason": "legacy-admin-supplier-api-not-implemented"
    },
    {
      "method": "*",
      "pathRegex": "^/api/v1/admin/warehouses(?:/.*)?$",
      "reason": "legacy-admin-warehouse-api-not-implemented"
    },
    {
      "method": "GET",
      "pathRegex": "^/api/v1/admin/reports/(expenses-by-month|harvest-by-season|incidents-summary|inventory-movements|task-performance|inventory-onhand|incident-statistics)$",
      "reason": "legacy-admin-report-endpoints-replaced-by-new-report-contract"
    },
    {
      "method": "GET",
      "pathRegex": "^/api/v1/admin/roles/\\{var\\}$",
      "reason": "admin-role-detail-by-id-not-supported"
    },
    {
      "method": "PUT",
      "pathRegex": "^/api/v1/admin/roles/\\{var\\}$",
      "reason": "admin-role-update-by-id-not-supported"
    },
    {
      "method": "POST",
      "pathRegex": "^/api/v1/admin/users/\\{var\\}/warnings$",
      "reason": "admin-user-warning-endpoint-not-implemented"
    },
    {
      "method": "PUT",
      "pathRegex": "^/api/v1/admin/farms/\\{var\\}$",
      "reason": "admin-farm-update-endpoint-not-exposed"
    },
    {
      "method": "*",
      "pathRegex": "^/api/v1/(farmer|buyer)/sales(?:/\\{var\\})?$",
      "reason": "sales-module-endpoints-not-exposed"
    },
    {
      "method": "GET",
      "pathRegex": "^/api/v1/expenses/analytics/(by-category|by-task|by-vendor|timeseries)$",
      "reason": "expense-advanced-analytics-endpoints-not-exposed"
    },
    {
      "method": "GET",
      "pathRegex": "^/api/v1/seasons/\\{var\\}/budget-tracker$",
      "reason": "season-budget-tracker-endpoint-not-exposed"
    },
    {
      "method": "POST",
      "pathRegex": "^/api/v1/expenses/\\{var\\}/attachment$",
      "reason": "expense-attachment-endpoint-not-exposed"
    },
    {
      "method": "*",
      "pathRegex": "^/api/v1/supplies/suppliers(?:/\\{var\\})?$",
      "reason": "supplies-supplier-command-endpoints-not-exposed"
    },
    {
      "method": "*",
      "pathRegex": "^/api/v1/harvests/\\{var\\}/quality-results$",
      "reason": "quality-result-endpoints-not-exposed"
    },
    {
      "method": "PUT",
      "pathRegex": "^/api/v1/quality-results/\\{var\\}$",
      "reason": "quality-result-endpoints-not-exposed"
    },
    {
      "method": "*",
      "pathRegex": "^/api/v1/reports(?:/\\{var\\})?$",
      "reason": "legacy-buyer-report-endpoints-not-exposed"
    },
    {
      "method": "GET",
      "pathRegex": "^/api/v1/search$",
      "reason": "global-search-endpoint-not-exposed"
    }
  ]
}
