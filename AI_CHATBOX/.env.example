APP_NAME="FarmTrace AI Chatbox"
API_PREFIX=/api/v1/ai

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3.5:2b
EMBEDDING_MODEL=nomic-embed-text

OLLAMA_THINK=false

CHROMA_DIR=./chroma_db
DATA_DIR=./data
COLLECTION_NAME=farmtrace_knowledge

CHUNK_SIZE=600
CHUNK_OVERLAP=80

DEFAULT_TOP_K=4
MAX_CONTEXT_CHARS=2200

NUM_PREDICT=512
NUM_CTX=4096

TEMPERATURE=0.1
TOP_K=20
TOP_P=0.8
REPEAT_PENALTY=1.1

KEEP_ALIVE=30m