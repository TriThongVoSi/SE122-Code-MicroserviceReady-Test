rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function isValidUid(value) {
      return value is string
        && value.matches('^u_[1-9][0-9]*$');
    }

    function hasValidDirectParticipantIds(participantIds) {
      return participantIds is list
        && participantIds.size() == 2
        && isValidUid(participantIds[0])
        && isValidUid(participantIds[1])
        && participantIds[0] != participantIds[1];
    }

    // Query-compatible guard for reads on /conversations.
    function isConversationParticipantFromResource() {
      return signedIn()
        && request.auth.uid in resource.data.participantIds;
    }

    function isConversationParticipant(conversationId) {
      return signedIn()
        && exists(/databases/$(database)/documents/conversations/$(conversationId))
        && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds;
    }

    function isConversationParticipantAfterWrite(conversationId) {
      return signedIn()
        && request.auth.uid in getAfter(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds;
    }

    function isDirectConversationCreate() {
      return signedIn()
        && request.resource.data.type == "direct"
        && hasValidDirectParticipantIds(request.resource.data.participantIds)
        && request.auth.uid in request.resource.data.participantIds;
    }

    function isDirectConversationUpdate() {
      return signedIn()
        && resource.data.type == "direct"
        && request.resource.data.type == "direct"
        && hasValidDirectParticipantIds(resource.data.participantIds)
        && request.resource.data.participantIds == resource.data.participantIds
        && request.auth.uid in resource.data.participantIds;
    }

    match /conversations/{conversationId} {
      allow create: if isDirectConversationCreate();
      allow read: if isConversationParticipantFromResource();
      allow update: if isDirectConversationUpdate();
      allow delete: if false;

      match /participants/{uid} {
        allow read: if isConversationParticipant(conversationId);
        allow create: if signedIn()
          && uid == request.auth.uid
          && isConversationParticipantAfterWrite(conversationId);
        allow update: if signedIn()
          && uid == request.auth.uid
          && isConversationParticipantAfterWrite(conversationId);
        allow delete: if false;
      }

      match /messages/{messageId} {
        allow read: if isConversationParticipant(conversationId);
        allow create: if isConversationParticipantAfterWrite(conversationId)
          && request.resource.data.senderUid == request.auth.uid
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() <= 2000;
        allow update, delete: if false;
      }
    }
  }
}
